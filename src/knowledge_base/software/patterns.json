  "design_patterns": {
    "repository": {
      "description": "Abstração da camada de acesso a dados",
      "code_example": "class UserRepository { async findById(id) { /* implementação */ } }",
      "languages": ["JavaScript", "TypeScript", "Java", "C#", "Python"]
    },
    "factory": {
      "description": "Criação de objetos sem especificar a classe exata",
      "code_example": "class PaymentProcessorFactory { static create(type) { switch(type) { case 'credit_card': return new CreditCardProcessor(); } } }",
      "languages": ["JavaScript", "TypeScript", "Java", "C#", "Python"]
    },
    "observer": {
      "description": "Padrão publish-subscribe para comunicação entre objetos",
      "code_example": "class EventEmitter { on(event, callback) { this.listeners[event].push(callback); } emit(event, data) { this.listeners[event].forEach(cb => cb(data)); } }",
      "languages": ["JavaScript", "TypeScript", "Java", "C#", "Python"]
    }
  },
