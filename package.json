{
  "name": "qg-ia-nexus-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "start": "npm start --workspace=apps/api",
    "dev": "npm run dev --workspace=apps/api",
    "test": "npm test --workspace=apps/api",
    "build": "turbo run build",
    "token:audit": "node scripts/token-audit.js",
    "assist:health": "bash scripts/assist.sh health",
    "assist:diag": "bash scripts/assist.sh diag-local",
    "assist:agentes": "bash scripts/assist.sh agentes-test",
    "assist:rotina": "bash scripts/assist.sh rotina",
    "assist:deploy": "bash scripts/assist.sh deploy"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@tailwindcss/oxide": "^4.2.2",
    "dotenv": "^17.3.1",
    "ssh2": "^1.17.0"
  }
}
